rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email in ['jeanesta81@gmail.com', 'manirihothierry8@gmail.com', 'manirihothierry250@gmail.com'] && request.auth.token.email_verified == true)
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$'); }

    // --- Entity Specific Validators ---
    function isValidService(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.imageUrl is string && data.imageUrl.size() <= 1048576 &&
             data.active is bool &&
             data.icon is string &&
             data.createdAt is timestamp;
    }

    function isValidGalleryItem(data) {
      return data.imageUrl is string && data.imageUrl.size() <= 1048576 &&
             data.title is string &&
             data.category is string &&
             data.uploadedAt is timestamp;
    }

    function isValidBook(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.pdfUrl is string && data.pdfUrl.size() <= 1048576 &&
             (!('coverUrl' in data) || (data.coverUrl is string && data.coverUrl.size() <= 1048576)) &&
             data.createdAt is timestamp;
    }

    function isValidRequest(data) {
      return data.fullName is string && data.fullName.size() <= 200 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.serviceNeeded is string &&
             data.createdAt is timestamp;
    }

    function isValidWebsiteSettings(data) {
      return data.company is map &&
             data.contact is map &&
             data.theme is map;
    }

    // --- Rules ---

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidService(incoming());
      allow delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidGalleryItem(incoming());
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow create: if isValidRequest(incoming()) && (incoming().status == 'pending');
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBook(incoming());
      allow update: if (isAdmin() && isValidBook(incoming())) || (incoming().diff(existing()).affectedKeys().hasOnly(['downloads']));
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidWebsiteSettings(incoming());
      allow delete: if isAdmin();
    }
  }
}
